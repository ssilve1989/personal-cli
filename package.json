{
	"name": "steve-cli",
	"version": "0.6.1",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"packageManager": "bun@1.3.9",
	"scripts": {
		"build": "bun build --compile ./src/index.ts --outfile dist/scli",
		"format": "biome format --fix",
		"lint": "biome lint --fix",
		"check": "biome check --diagnostic-level=error --fix",
		"lint:ci": "biome ci --diagnostic-level=error",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"preview-notes": "bun scripts/preview-notes.ts",
		"prepare": "lefthook install",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@semantic-release/changelog": "latest",
		"@semantic-release/git": "latest",
		"@types/bun": "1.3.12",
		"conventional-changelog-conventionalcommits": "9.3.1",
		"lefthook": "^2.1.5"
	},
	"peerDependencies": {
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"commander": "^14.0.3",
		"marked": "17",
		"marked-terminal": "^7.3.0"
	}
}
